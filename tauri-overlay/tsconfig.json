{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "resolveJsonModule": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "strict": false,
        "jsx": "react-jsx",
        "types": ["vite/client", "node"]
    },
    "include": ["src/**/*"]
}
